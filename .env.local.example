# Helius RPC and API Keys
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_API_KEY
NEXT_PUBLIC_HELIUS_API_KEY=YOUR_HELIUS_API_KEY

# Wallet Configuration (Add your 7 wallet private keys)
WALLET_1_PRIVATE_KEY=[your_wallet_1_private_key_as_json_array]
WALLET_2_PRIVATE_KEY=[your_wallet_2_private_key_as_json_array]
WALLET_3_PRIVATE_KEY=[your_wallet_3_private_key_as_json_array]
WALLET_4_PRIVATE_KEY=[your_wallet_4_private_key_as_json_array]
WALLET_5_PRIVATE_KEY=[your_wallet_5_private_key_as_json_array]
WALLET_6_PRIVATE_KEY=[your_wallet_6_private_key_as_json_array]
WALLET_7_PRIVATE_KEY=[your_wallet_7_private_key_as_json_array]

